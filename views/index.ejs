<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
     <%- include('partials/header') %>
    <h1><%= title %></h1>
    
    <ul>
        <% messages.forEach((message, index) => { %>
            <li><%= message.text %> - <%= message.user %> (<%= message.added %>)
                <a href="/message/<%= index %>">Open</a>
                <a href="/delete/<%= index %>">Delete</a>
            </li>
        <% }) %>
    </ul>
</body>
</html>